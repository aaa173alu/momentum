{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": ["warn"],
    "consistent-return": ["warn"],
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "max-len": ["warn", { "code": 120 }],
    "no-restricted-syntax": ["warn"],
    "no-await-in-loop": ["warn"]
  }
}

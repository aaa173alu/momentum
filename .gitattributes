# Auto detect text files and normalize line endings to LF
* text=auto

# JavaScript and related files
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.jar binary
